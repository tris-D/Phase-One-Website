<%- include("0_header.ejs") %>
<%- include("0_nav.ejs") %>


<!-- ===============================================-->
<!--    Main Content-->
<!-- ===============================================-->
<main class="main min-vh-100" id="top">

  <!-- ============================================-->
  <!-- Preloader ==================================-->
  <div class="preloader" id="preloader">
    <div class="loader">
      <div class="line-scale-pulse-out-rapid">
        <div> </div>
        <div></div>
        <div></div>
        <div></div>
        <div> </div>
      </div>
    </div>
  </div>
  <!-- ============================================-->
  <!-- End of Preloader ===========================-->


  <!-- ============================================-->
  <!-- <section> begin ============================-->
  <section class="py-0" id="page-contact">

    <div class="container-fluid">
      <div class="row">
        <div class="col-lg-6 bg-body pt-8 pb-6">
          <div class="row h-100 flex-center">
            <div class="col-lg-8" data-zanim-lg='{"animation":"slide-left","delay":0.6}' data-zanim-trigger="scroll">
              <h1 class="text-decoration-underline d-inline-block mb-4 mb-lg-6">contact.</h1>
              <p class="fw-bold mb-0">Main Office:<span class="ms-2 fw-normal">Brittania Woods Community House<br />115 Ritchie St Unit #9 - Ottawa, ON K2B 6E8</span></p>
              <p class="fw-bold mb-0">2026 Classes:<span class="ms-2 fw-normal">Maison de la Francophonie d'Ottawa<br />2720 Richmond Road - Ottawa, ON K2B 6S2</span></p>
              <p class="fw-bold mb-0">Phone:<span class="ms-2 fw-normal"><a class="text-body" href="tel:+16136974868">+1 (613) 697-4868</a></span></p>
              <p class="fw-bold mb-4">E-mail:<span class="ms-2 fw-normal fst-italic"><a class="text-body" href="mailto:phase1programs@gmail.com">phase1programs@gmail.com</a></span></p>
              <div class="mt-3"><a class="btn btn-dark btn-sm me-2" href="https://www.facebook.com/profile.php?id=61591817481705" target="_blank"><span class="fab fa-facebook-f" data-fa-transform="grow-6"></span></a><a class="btn btn-dark btn-sm me-2" href="https://www.youtube.com/channel/UC2IsoxNoegFDvPntwqUNTzA" target="_blank"><span class="fab fa-youtube" data-fa-transform="grow-6"></span></a><a class="btn btn-dark btn-sm me-2" href="https://www.linkedin.com/company/133395818/" target="_blank"><span class="fab fa-linkedin-in" data-fa-transform="grow-6"></span></a><a class="btn btn-dark btn-sm" href="https://www.instagram.com/phase1ottawa/" target="_blank"><span class="fab fa-instagram" data-fa-transform="grow-6"></span></a></div>
              <h3 class="mt-5">Give us a shout</h3>
              <% if (typeof success !== "undefined" && success) { %>
                <div class="alert alert-success mt-3" role="alert"><%= success %></div>
              <% } %>
              <% if (typeof error !== "undefined" && error) { %>
                <div class="alert alert-danger mt-3" role="alert"><%= error %></div>
              <% } %>
              <form class="mt-4" id="contactForm" method="POST" action="/contact">
                <input class="form-control" type="text" name="name" placeholder="Your Name" aria-label="Your name" required />
                <input class="form-control mt-3" type="email" name="email" placeholder="Your Email" aria-label="Your email" required />
                <input class="form-control mt-3" type="text" name="phone" placeholder="Phone Number" aria-label="Phone number" />
                <textarea class="form-control mt-3" name="message" rows="7" placeholder="Your Message" aria-label="Your message" required></textarea>
                <!-- Honeypot: hidden from real users, bots tend to fill it. Do not remove. -->
                <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
                  <label for="website">Leave this field empty</label>
                  <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                </div>
                <div class="d-grid">
                  <button class="btn btn-block btn-dark mt-4" id="contactSubmitBtn" type="submit"><span class="contact-submit-label">Send<span class="fa fa-paper-plane ms-1"></span></span><span class="contact-submit-loading d-none">Sending<span class="fa fa-spinner fa-spin ms-2"></span></span></button>
                </div>
              </form>
            </div>
          </div>
        </div>
        <div class="col-lg-6 px-0">
          <div class="sticky-top overflow-hidden-y">
            <iframe class="w-100 min-vh-100 d-none d-lg-block" style="border:0;" src="https://www.google.com/maps/embed?pb=!3m2!1sen!2sca!4v1783876113912!5m2!1sen!2sca!6m8!1m7!1sMsmgLsJlCbvyUbE0o0otBA!2m2!1d45.35890120185134!2d-75.79356392879784!3f115.94552!4f0!5f0.7820865974627469" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Phase 1 location map"></iframe>
            <!-- Mobile map -->
            <iframe class="w-100 min-vh-50 d-lg-none" style="border:0;" src="https://www.google.com/maps/embed?pb=!3m2!1sen!2sca!4v1783876113912!5m2!1sen!2sca!6m8!1m7!1sMsmgLsJlCbvyUbE0o0otBA!2m2!1d45.35890120185134!2d-75.79356392879784!3f115.94552!4f0!5f0.7820865974627469" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Phase 1 location map"></iframe>
          </div>
        </div>
      </div>
    </div>
    <!-- end of .container-->

  </section>
  <!-- <section> close ============================-->
  <!-- ============================================-->

</main>
<!-- ===============================================-->
<!--    End of Main Content-->
<!-- ===============================================-->

<script src="../assets/js/loading.js"></script>
<%- include("0_end.ejs") %>